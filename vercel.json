{
  "buildCommand": "bash build.sh && npm install",
  "installCommand": "npm install",
  "public": "public",
  "routes": [
    {
      "src": "/submissions",
      "dest": "/submissions.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/$1.html"
    },
    {
      "src": "/(?!api)(.*)(\\..*)?$",
      "dest": "/$1"
    }
  ]
}

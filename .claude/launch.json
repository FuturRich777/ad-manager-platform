{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Express)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=backend"],
      "port": 5000
    },
    {
      "name": "Frontend (React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=frontend"],
      "port": 3000
    },
    {
      "name": "Docker (PostgreSQL + Redis)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up"],
      "port": 5432
    }
  ]
}
